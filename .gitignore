# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
build_tmp/
.env
.venv
venv/
env/

# Bundled ffmpeg binaries are too large for git (~100 MB each).
# Run  python get_ffmpeg.py  to fetch them before building.
ffmpeg/*.exe
ffmpeg/*
!ffmpeg/.gitkeep

# Output videos (keep the folder, ignore the content)
ModifiedVids/*
!ModifiedVids/.gitkeep

# Source videos are user-provided; keep folder, ignore content
SourceVids/*
!SourceVids/.gitkeep

# NOTE: branding images are intentionally NOT ignored. The app's intro/outro
# live in assets/intro_template.png and assets/AppendAsset.png and ARE committed
# so the real WGU art travels with the repo. Replace those two files to
# update the branding, then rebuild/release.

# The WGU PowerPoint template is NOT committed (WGU-internal). Drop it into
# template/ locally to regenerate the branding PNGs with render_template.py.
*.pptx

# OS / editor artefacts
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
