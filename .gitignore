# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
build_tmp/
.env
.venv
venv/
env/

# Bundled ffmpeg binaries are too large for git (~100 MB each).
# Run  python get_ffmpeg.py  to fetch them before building.
ffmpeg/*.exe
ffmpeg/*
!ffmpeg/.gitkeep

# Output videos (keep the folder, ignore the content)
ModifiedVids/*
!ModifiedVids/.gitkeep

# Source videos are user-provided; keep folder, ignore content
SourceVids/*
!SourceVids/.gitkeep

# Legacy user-provided image assets in the project root (old CLI location).
# The app's default branding lives in assets/ and IS committed (placeholders).
/PrependAsset.png
/AppendAsset.png

# OS / editor artefacts
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
